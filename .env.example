# .env.example
# Copy this file to .env.local and fill in your values

# Anthropic API Key - get yours at https://console.anthropic.com
# This is passed automatically when using Claude.ai artifacts
# For standalone deployment, set this in your environment
REACT_APP_ANTHROPIC_API_KEY=your_api_key_here

# Google Drive API (optional - for folder-level Drive imports)
# Get credentials from https://console.cloud.google.com
REACT_APP_GOOGLE_CLIENT_ID=your_google_client_id_here
REACT_APP_GOOGLE_API_KEY=your_google_api_key_here

# Blurb Print API (optional - for direct print integration)
# Get API access at https://www.blurb.com/api
REACT_APP_BLURB_API_KEY=your_blurb_api_key_here
